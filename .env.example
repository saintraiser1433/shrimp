# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth – required for JWT session encryption. Generate a new one with:
#   openssl rand -base64 32
# Do not use the placeholder below in production. If you change this, existing session cookies will be invalid (users must sign in again).
AUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
