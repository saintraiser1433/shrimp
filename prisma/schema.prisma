// Prisma schema for Panso Nestor Sherald Shrimp Farming Management System
// NOTE: Never abbreviate "Panso Nestor Sherald" as "PNS".
// NextAuth v5 + PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth required models ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // hashed for credentials provider
  image         String?
  phone         String?   // Philippine mobile +639… for SMS
  role          UserRole  @default(FARMER)

  accounts         Account[]
  sessions         Session[]
  shrimpInventories ShrimpInventory[]       @relation("ShrimpInventoryOwner")
  feedingSchedulesAssigned FeedingSchedule[] @relation("AssignedFarmer")
  waterMaintenanceSchedulesAssigned WaterMaintenanceSchedule[] @relation("WaterMaintenanceAssignedFarmer")
  waterMaintenanceCompletionRequests WaterMaintenanceSchedule[] @relation("WaterMaintenanceCompletionRequestedBy")
  feedingConfirmations FeedingConfirmation[]
  harvestSchedules HarvestSchedule[]
  harvests         Harvest[]
  notifications   Notification[]
  pondStockingsAssigned PondStocking[]      @relation("PondStockingAssignedFarmer")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// --- Domain models ---
enum UserRole {
  ADMIN
  FARMER
}

model Pond {
  id       String   @id @default(cuid())
  name     String
  location String?
  size     String?  // e.g. "1000 sqm"
  status   String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE

  waterMaintenanceSchedules WaterMaintenanceSchedule[]
  pondShrimpAssignments     PondShrimpAssignment[]
  feedingSchedules          FeedingSchedule[]
  harvestSchedules          HarvestSchedule[]
  harvests                  Harvest[]
  pondStockings             PondStocking[]
}

model WaterMaintenanceSchedule {
  id                    String    @id @default(cuid())
  pondId                String
  scheduledAt           DateTime
  type                  String    // e.g. WATER_CHANGE, AERATION_CHECK, PH_CHECK
  notes                 String?
  completedAt           DateTime?
  assignedFarmerId      String?
  completionRequestedBy  String?   // farmer who requested completion; admin must approve or reject

  pond          Pond  @relation(fields: [pondId], references: [id], onDelete: Cascade)
  assignedFarmer User? @relation("WaterMaintenanceAssignedFarmer", fields: [assignedFarmerId], references: [id], onDelete: SetNull)
  requestedBy    User? @relation("WaterMaintenanceCompletionRequestedBy", fields: [completionRequestedBy], references: [id], onDelete: SetNull)
}

model ShrimpType {
  id                         String   @id @default(cuid())
  name                       String
  description                String?
  defaultFeedingIntervalDays Int?
  defaultFeedingQty          Decimal? @db.Decimal(12, 2)
  defaultFeedingUnitId       String?
  expectedHarvestDays        Int?
  expectedHarvestQty         Decimal? @db.Decimal(12, 2)
  expectedHarvestUnitId      String?

  defaultFeedingUnit  ShrimpUnit?       @relation("ShrimpTypeDefaultFeedingUnit", fields: [defaultFeedingUnitId], references: [id], onDelete: SetNull)
  expectedHarvestUnit ShrimpUnit?       @relation("ShrimpTypeExpectedHarvestUnit", fields: [expectedHarvestUnitId], references: [id], onDelete: SetNull)
  shrimpInventories   ShrimpInventory[]
  feedingSchedules    FeedingSchedule[]
  harvestSchedules    HarvestSchedule[]
  growthStages        ShrimpGrowthStage[]
  pondStockings       PondStocking[]
}

model ShrimpGrowthStage {
  id                    String   @id @default(cuid())
  shrimpTypeId          String
  stageName             String
  startDayFromStocking  Int
  endDayFromStocking    Int
  feedId                String?
  feedQtyPerSession     Decimal  @db.Decimal(12, 2)
  feedingSessionsPerDay Int      @default(1)
  feedUnitId            String?
  sortOrder             Int      @default(0)

  shrimpType ShrimpType      @relation(fields: [shrimpTypeId], references: [id], onDelete: Cascade)
  feed       FeedsInventory? @relation(fields: [feedId], references: [id], onDelete: SetNull)
  feedUnit   ShrimpUnit?     @relation("ShrimpGrowthStageFeedUnit", fields: [feedUnitId], references: [id], onDelete: SetNull)
}

model ShrimpUnit {
  id           String   @id @default(cuid())
  name         String   // e.g. KILO, GRAM
  abbreviation String?

  defaultFeedingShrimpTypes  ShrimpType[] @relation("ShrimpTypeDefaultFeedingUnit")
  expectedHarvestShrimpTypes ShrimpType[] @relation("ShrimpTypeExpectedHarvestUnit")
  growthStageFeedUnits       ShrimpGrowthStage[] @relation("ShrimpGrowthStageFeedUnit")
  pondStockingInitialUnits   PondStocking[] @relation("PondStockingInitialUnit")
  shrimpInventories          ShrimpInventory[]
  feedsInventories           FeedsInventory[]
  harvestSchedules           HarvestSchedule[]
  harvests                   Harvest[]
}

model ShrimpInventory {
  id           String   @id @default(cuid())
  shrimpTypeId String
  unitId       String
  quantity     Decimal  @db.Decimal(12, 2)
  status       String   @default("AVAILABLE") // AVAILABLE, IN_POND, HARVESTED
  userId       String   // farmer who created/owns this entry
  createdAt    DateTime @default(now())

  shrimpType ShrimpType @relation(fields: [shrimpTypeId], references: [id], onDelete: Cascade)
  unit       ShrimpUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user       User       @relation("ShrimpInventoryOwner", fields: [userId], references: [id], onDelete: Cascade)
  pondAssignments PondShrimpAssignment[]
}

model PondShrimpAssignment {
  id                 String   @id @default(cuid())
  pondId             String
  shrimpInventoryId  String
  assignedAt         DateTime @default(now())
  assignedById       String?

  pond            Pond            @relation(fields: [pondId], references: [id], onDelete: Cascade)
  shrimpInventory ShrimpInventory @relation(fields: [shrimpInventoryId], references: [id], onDelete: Cascade)
}

model FeedsInventory {
  id                String   @id @default(cuid())
  name              String
  quantity          Decimal  @db.Decimal(12, 2)
  unitId            String
  restockThreshold  Decimal? @db.Decimal(12, 2)

  unit              ShrimpUnit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  schedules         FeedingSchedule[]
  growthStages      ShrimpGrowthStage[]
}

model PondStocking {
  id                  String    @id @default(cuid())
  pondId              String
  shrimpTypeId        String
  stockedAt           DateTime  @default(now())
  initialQuantity     Decimal   @db.Decimal(12, 2)
  initialUnitId       String?
  expectedHarvestDate DateTime?
  expectedHarvestQty  Decimal?  @db.Decimal(12, 2)
  assignedFarmerId    String?
  status              String    @default("ACTIVE") // ACTIVE, HARVESTED, TERMINATED
  notes               String?
  createdAt           DateTime  @default(now())

  pond             Pond              @relation(fields: [pondId], references: [id], onDelete: Cascade)
  shrimpType       ShrimpType        @relation(fields: [shrimpTypeId], references: [id], onDelete: Cascade)
  initialUnit      ShrimpUnit?       @relation("PondStockingInitialUnit", fields: [initialUnitId], references: [id], onDelete: SetNull)
  assignedFarmer   User?             @relation("PondStockingAssignedFarmer", fields: [assignedFarmerId], references: [id], onDelete: SetNull)
  feedingSchedules FeedingSchedule[]
  harvestSchedules HarvestSchedule[]
}

model FeedingSchedule {
  id                 String   @id @default(cuid())
  pondId             String
  feedId             String
  shrimpTypeId       String?
  pondStockingId     String?
  growthStageName    String?
  scheduledAt        DateTime
  quantity           Decimal  @db.Decimal(12, 2)
  status             String   @default("PENDING") // PENDING, DELAYED, COMPLETED, MISSED
  assignedFarmerId   String?

  pond             Pond                  @relation(fields: [pondId], references: [id], onDelete: Cascade)
  feed             FeedsInventory         @relation(fields: [feedId], references: [id], onDelete: Cascade)
  shrimpType       ShrimpType?            @relation(fields: [shrimpTypeId], references: [id], onDelete: SetNull)
  pondStocking     PondStocking?          @relation(fields: [pondStockingId], references: [id], onDelete: SetNull)
  assignedFarmer   User?                  @relation("AssignedFarmer", fields: [assignedFarmerId], references: [id], onDelete: SetNull)
  confirmations    FeedingConfirmation[]
}

model FeedingConfirmation {
  id          String   @id @default(cuid())
  scheduleId  String
  farmerId    String
  confirmedAt DateTime @default(now())
  dispensedQty Decimal @db.Decimal(12, 2)
  notes       String?
  isLate      Boolean  @default(false)
  lateReason  String?

  schedule FeedingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  farmer   User            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
}

model HarvestSchedule {
  id             String   @id @default(cuid())
  pondId         String
  shrimpTypeId   String?
  pondStockingId String?
  scheduledAt    DateTime
  estimatedQty   Decimal  @db.Decimal(12, 2)
  unitId         String
  farmerId       String?
  status         String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED

  pond         Pond          @relation(fields: [pondId], references: [id], onDelete: Cascade)
  shrimpType   ShrimpType?   @relation(fields: [shrimpTypeId], references: [id], onDelete: SetNull)
  pondStocking PondStocking? @relation(fields: [pondStockingId], references: [id], onDelete: SetNull)
  unit         ShrimpUnit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  farmer       User?         @relation(fields: [farmerId], references: [id], onDelete: SetNull)
  harvests     Harvest[]
}

model Harvest {
  id          String   @id @default(cuid())
  scheduleId  String?
  pondId      String
  farmerId    String
  actualQty   Decimal  @db.Decimal(12, 2)
  unitId      String
  harvestedAt DateTime @default(now())
  notes       String?

  schedule HarvestSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  pond     Pond             @relation(fields: [pondId], references: [id], onDelete: Cascade)
  farmer   User             @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  unit     ShrimpUnit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // LOW_STOCK, MISSED_FEEDING, NEW_HARVEST, etc.
  message    String
  read       Boolean  @default(false)
  relatedId  String?  // optional reference to related entity
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Singleton: one row stores SMS gateway settings for the app (reused by Settings and other components)
model SmsGatewayConfig {
  id         String   @id @default(cuid())
  gatewayUrl String
  username   String
  password   String
  testPhone  String?  // optional default test number (+639…)
  updatedAt  DateTime @updatedAt
}
